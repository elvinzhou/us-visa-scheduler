# Copy this to .env and fill in your values (the .env file is gitignored)

# Applicant name exactly as shown in the scheduling system
APPLICANT_NAME=Your Full Name

# Email credentials for notifications
EMAIL_SENDER=your_email@qq.com
EMAIL_PASSWORD=your_smtp_app_password
EMAIL_RECEIVER=your_receiver@example.com

# Optional — defaults shown below
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=465
