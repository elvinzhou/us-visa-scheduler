# Copy this to .env and fill in your values (the .env file is gitignored)

# Applicant name exactly as shown in the scheduling system
APPLICANT_NAME=Your Full Name

# Visa scheduling account credentials
VISA_USERNAME=your_email@example.com
VISA_PASSWORD=your_password

# Security question answers (for whichever 2 of 3 the site shows)
SECURITY_A1=answer_to_question_1
SECURITY_A2=answer_to_question_2
SECURITY_A3=answer_to_question_3

# OpenAI API key (used for captcha solving via gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Email credentials for notifications
EMAIL_SENDER=your_email@qq.com
EMAIL_PASSWORD=your_smtp_app_password
EMAIL_RECEIVER=receiver1@example.com,receiver2@example.com  # comma-separated

# Optional — defaults shown below
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=465
